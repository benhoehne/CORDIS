{
  "_comment": "CORDIS extraction configuration. Edit query and summary_fields as needed.",
  "query": "(relations/associations/organization/legalName='UHEI' OR relations/associations/organization/shortName='UHEI' OR relations/associations/organization/legalName='UKHD' OR relations/associations/organization/shortName='UKHD') AND startDate>=2014-01-01",
  "output_prefix": "data/cordis_",
  "summary_fields": [
    "id",
    "acronym",
    "title",
    "teaser",
    "objective",
    "totalCost",
    "startDate",
    "endDate",
    "duration",
    "status",
    "grantDoi",
    "coordinator_name",
    "coordinator_shortName",
    "topic_code",
    "call_identifier",
    "fundingScheme"
  ],
  "query_dn": "/project/relations/associations/relatedMasterCall/call/identifier='*DN*','*ITN*' AND (relations/associations/organization/legalName='UHEI' OR relations/associations/organization/shortName='UHEI' OR relations/associations/organization/legalName='UKHD' OR relations/associations/organization/shortName='UKHD')",
  "query_erc": "/project/relations/associations/relatedMasterCall/call/identifier='ERC-*' AND (relations/associations/organization/legalName='UHEI' OR relations/associations/organization/shortName='UHEI' OR relations/associations/organization/legalName='UKHD' OR relations/associations/organization/shortName='UKHD')"
}
